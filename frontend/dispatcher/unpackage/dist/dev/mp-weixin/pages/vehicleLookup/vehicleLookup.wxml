<view class="page"><view class="map-container"><map class="map" latitude="{{a}}" longitude="{{b}}" scale="{{c}}" markers="{{d}}" polygons="{{e}}" show-location="{{true}}" bindmarkertap="{{f}}"></map></view><view class="result-panel"><view class="result-meta"><text class="result-text">共 {{g}} 辆禁停区车辆</text></view><scroll-view class="result-list" scroll-y><view wx:for="{{h}}" wx:for-item="item" wx:key="h" class="{{['result-item', 'ui-pressable', item.i && 'active']}}" hover-class="ui-pressable-hover" hover-stay-time="70" bindtap="{{item.j}}"><view class="result-header"><text class="result-name">{{item.a}}</text><text class="result-distance">{{item.b}}</text></view><view class="result-subline"><text class="result-area">{{item.c}}</text></view><view class="result-details"><text class="detail-text">状态 {{item.d}}</text><text class="detail-text">电量 {{item.e}}</text><text class="{{['detail-text', item.g && 'fault-text']}}">{{item.f}}</text></view></view><view wx:if="{{i}}" class="empty-state"><text class="empty-text">当前没有位于禁停区的车辆</text></view></scroll-view></view></view>